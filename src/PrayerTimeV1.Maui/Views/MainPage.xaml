<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PrayerTimeV1.Maui.ViewModels"
             x:Class="PrayerTimeV1.Maui.Views.MainPage"
             BackgroundColor="#060b14"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="16">

        <VerticalStackLayout Grid.Row="0" Spacing="4" Padding="0,20,0,0">
            <Label Text="WAKTU SOLAT" FontSize="28" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="#c9a84c" />
            <Label Text="Negara Brunei Darussalam" FontSize="14"
                   HorizontalOptions="Center" TextColor="#94a3b8" />
            <Label Text="{Binding DateDisplay}" FontSize="16" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="#e8edf8" Margin="0,12,0,0" />
            <Label Text="{Binding HijriDisplay}" FontSize="14"
                   HorizontalOptions="Center" TextColor="#c9a84c" />
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="Center" Margin="0,8,0,0">
            <Label Text="🔔 Azan" FontSize="13" TextColor="#94a3b8" VerticalOptions="Center" />
            <Switch x:Name="AzanSwitch" IsToggled="True" OnColor="#10b981" />
        </HorizontalStackLayout>

        <Frame Grid.Row="2" BackgroundColor="#0d1525"
               BorderColor="#c9a84c" CornerRadius="12"
               Padding="16" Margin="0,16" HasShadow="False">
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="{Binding CurrentPrayerName, StringFormat='Sekarang: {0}'}"
                       FontSize="13" HorizontalOptions="Center" TextColor="#94a3b8" />
                <Label Text="{Binding NextPrayerName, StringFormat='Seterusnya: {0}'}"
                       FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#10b981" />
                <Label Text="{Binding CountdownDisplay}"
                       FontSize="36" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#c9a84c" />
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="3" ItemsSource="{Binding PrayerSlots}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PrayerSlotViewModel">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="12,8" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="{Binding Icon}" FontSize="18" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding Name}" FontSize="16" FontAttributes="Bold"
                               VerticalOptions="Center" TextColor="{Binding Color}" />
                        <Label Grid.Column="2" Text="{Binding Time}" FontSize="16"
                               VerticalOptions="Center" HorizontalOptions="End" TextColor="{Binding Color}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="3" IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}" Color="#c9a84c" VerticalOptions="Center" />
        <Label Grid.Row="3" Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}"
               TextColor="#ef4444" HorizontalOptions="Center" VerticalOptions="Center" />

        <Label Grid.Row="4" Text="Waktu Solat · Brunei Darussalam"
               FontSize="11" HorizontalOptions="Center" TextColor="#64748b" Margin="0,0,0,8" />
    </Grid>
</ContentPage>
